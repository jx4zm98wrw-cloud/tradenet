# =============================================================================
# Tradenet — Trademark Gazette workbench
# =============================================================================
# Copy to `app/.env` for local dev. In production, supply these via the
# orchestrator's secret manager (k8s Secrets / AWS Parameter Store / Vault).
# DO NOT commit a populated .env file.

# ---- Identity ----
TM_ENV=development                      # development | staging | production

# ---- Database ----
TM_DATABASE_URL=postgresql+asyncpg://tm:tm@localhost:5435/tm
TM_DATABASE_URL_SYNC=postgresql+psycopg2://tm:tm@localhost:5435/tm

# ---- Redis (RQ workers + rate-limit storage) ----
TM_REDIS_URL=redis://localhost:6380/0

# ---- Filesystem ----
TM_UPLOAD_DIR=/tmp/tm_uploads
TM_DATA_DIR=/absolute/path/to/claude_csvbuilder

# ---- Security ----
# Comma-separated list of CORS origins. Empty disables cross-origin.
TM_CORS_ORIGINS=http://localhost:3000

# HMAC key for signed cookies / JWTs. MUST be a long random string in prod.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
TM_SECRET_KEY=dev-only-do-not-use-in-prod

# Upload size cap (bytes) — default 500 MB.
TM_MAX_UPLOAD_BYTES=524288000

# Rate limits (slowapi syntax: "<count>/<period>")
TM_RATE_LIMIT_DEFAULT=120/minute
TM_RATE_LIMIT_UPLOAD=10/minute

# ---- Worker tuning ----
# Rows the worker bulk-inserts per session.add_all() call. Larger = fewer
# round trips; smaller = lower memory per batch. Default 200 is tuned for
# the 2026 gazette set; raise it if you hit lots of small gazettes.
TM_WORKER_BATCH_SIZE=200

# ---- Observability ----
TM_SENTRY_DSN=                          # blank = disabled
TM_ENABLE_PROMETHEUS=true

# ---- docker-compose overrides (read by app/docker-compose.yml) ----
POSTGRES_USER=tm
POSTGRES_PASSWORD=tm
POSTGRES_DB=tm
POSTGRES_PORT=5435
REDIS_PORT=6380
