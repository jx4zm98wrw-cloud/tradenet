{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  // Exclude Playwright e2e specs + config from the Next.js typecheck —
  // they pull in @playwright/test (a devDep only present in test runs)
  // and don't belong in the Next.js bundle graph. Playwright runs its
  // own ts-node-based check at test time.
  "exclude": ["node_modules", "tests/e2e", "playwright.config.ts"]
}
