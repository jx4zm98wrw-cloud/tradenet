# Tradenet QA suite — environment. Copy to `qa/.env` and edit. NEVER commit `.env`.
# Read-only: the suite only issues GET requests + read-only SQL.

# --- Target app (local dev defaults) ---
TNQA_BASE_URL=http://localhost:8000
# Optional bearer token / cookie if the search API requires auth in your env.
# Leave blank for an unauthenticated local dev target (the smoke gate verifies).
TNQA_AUTH_TOKEN=

# --- Ground-truth Postgres (READ-ONLY; same DB the API serves) ---
# Dev default from app/docker-compose.yml (postgres on :5435).
TNQA_DB_DSN=postgresql://tm:tm@localhost:5435/tm

# --- Pacing (the search API rate-limits ~20 rps with HTTP 429; stay under it.
#     The client also backs off + retries on 429/503 honoring Retry-After). ---
TNQA_MAX_RPS=5
TNQA_MAX_RETRIES=8
TNQA_MAX_CONCURRENCY=8
